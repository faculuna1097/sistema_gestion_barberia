{
  "rewrites": [
    {
      "source": "/turnos/:path*",
      "destination": "https://sistema-gestion-barberia-turnero.vercel.app/:path*",
      "has": [{ "type": "host", "value": "demo.barbermanager.app" }]
    },
    {
      "source": "/barbero/:path*",
      "destination": "https://sistema-gestion-barberia-barbero.vercel.app/:path*",
      "has": [{ "type": "host", "value": "demo.barbermanager.app" }]
    }
  ]
}
